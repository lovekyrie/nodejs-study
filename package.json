{
  "name": "nodejs-study",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=9.6.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @nodejs-study/api dev",
    "dev:worker": "pnpm --filter @nodejs-study/worker dev",
    "db:generate": "pnpm --filter @nodejs-study/database prisma:generate",
    "db:validate": "pnpm --filter @nodejs-study/database prisma:validate",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "lesson:01": "node --env-file .env --import tsx lessons/00-foundation-warmup/01-runtime-cli/src/index.ts",
    "lesson:02": "node --import tsx lessons/00-foundation-warmup/02-rps-cli/src/index.ts",
    "lesson:03": "node --import tsx lessons/00-foundation-warmup/03-modules/src/index.ts",
    "lesson:04": "node --import tsx lessons/00-foundation-warmup/04-events-async-io/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "prisma": "^7.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "volta": {
    "node": "24.16.0"
  }
}
